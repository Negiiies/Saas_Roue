generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  businesses  Business[]
}

model Business {
  id               Int       @id @default(autoincrement())
  name             String
  slug             String    @unique
  city             String?
  zipCode          String?
  status           String    @default("trial")
  trialEndsAt      DateTime?
  companyId        Int
  company          Company   @relation(fields: [companyId], references: [id])
  createdAt        DateTime  @default(now())

  hasEngagement    Boolean   @default(false)
  engagementStart  DateTime?
  engagementMonths Int       @default(12)
  autoRenew        Boolean   @default(false)
  engagementStatus String    @default("none")

  wheels           Wheel[]
}

model Wheel {
  id              Int      @id @default(autoincrement())
  name            String
  googleReviewUrl String?
  businessId      Int
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  rewards         Reward[]
  scans           Scan[]
}

model Reward {
  id          Int      @id @default(autoincrement())
  label       String
  probability Float
  color       String   @default("#8B5CF6")
  emoji       String   @default("\ud83c\udf81")
  isLosing    Boolean  @default(false)
  wheelId     Int
  wheel       Wheel    @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  scans       Scan[]
}

model Scan {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  secretCode  String?   @unique
  ip          String
  fingerprint String?
  hasSpun     Boolean   @default(false)
  rewardId    Int?
  reward      Reward?   @relation(fields: [rewardId], references: [id])
  wheelId     Int
  wheel       Wheel     @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  status      String    @default("pending")
  wonAt       DateTime?
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}
